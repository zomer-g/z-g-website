generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role      @default(ADMIN)
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  createdAt     DateTime  @default(now())
}

model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  content     Json
  excerpt     String?
  coverImage  String?
  status      PostStatus @default(DRAFT)
  author      User       @relation(fields: [authorId], references: [id])
  authorId    String
  category    String?
  tags        String[]   @default([])
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  seoTitle    String?
  seoDesc     String?
}

model Page {
  id           String     @id @default(cuid())
  slug         String     @unique
  title        String
  content      Json
  draftContent Json?
  status       PageStatus @default(DRAFT)
  updatedAt    DateTime   @updatedAt
  publishedAt  DateTime?
  seoTitle     String?
  seoDesc      String?
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

model Service {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String
  content     Json
  icon        String?
  order       Int     @default(0)
  isActive    Boolean @default(true)
  seoTitle    String?
  seoDesc     String?
}

model Media {
  id        String   @id @default(cuid())
  url       String
  filename  String
  mimeType  String
  size      Int
  alt       String?
  createdAt DateTime @default(now())
}

model Submission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MediaAppearance {
  id           String   @id @default(cuid())
  title        String
  description  String
  type         String // "video" | "article" | "podcast"
  source       String
  date         String
  url          String?
  thumbnailUrl String?
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model SiteSettings {
  id   String @id @default("main")
  data Json
}

enum Role {
  ADMIN
  // GUEST users can sign in via SSO but only see WhatsApp workspaces
  // they're on the allowlist for. They cannot reach /admin or any other
  // private dashboard. The role is assigned at signIn time based on
  // whether the email is in ADMIN_EMAILS env or only in
  // WhatsappWorkspaceAccess rows.
  GUEST
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─── Sanegoria Dashboard (Criminal Proceedings Analysis) ───

model SanegoriaCase {
  id             Int       @id @default(autoincrement())
  caseId         String    @unique @map("case_id")
  caseName       String?   @map("case_name")
  acceptanceDate DateTime? @map("acceptance_date")
  closedDate     DateTime? @map("closed_date")
  verdict        String?
  courtId        String?   @map("court_id")
  isPd           Boolean   @default(false) @map("is_pd")
  isSole         Boolean   @default(false) @map("is_sole")

  @@index([isPd])
  @@index([courtId])
  @@index([acceptanceDate])
  @@index([verdict])
  @@index([isPd, acceptanceDate])
  @@index([isPd, courtId])
  @@index([isPd, verdict])
  @@index([isPd, acceptanceDate, courtId])
  @@index([isPd, acceptanceDate, verdict])
  @@map("sanegoria_cases")
}

model SanegoriaHearing {
  id          Int       @id @default(autoincrement())
  caseId      String    @map("case_id")
  meetingDate DateTime? @map("meeting_date")
  status      String?
  type        String?
  isPd        Boolean   @default(false) @map("is_pd")

  @@index([caseId])
  @@index([isPd])
  @@index([caseId, isPd])
  @@index([isPd, meetingDate])
  @@map("sanegoria_hearings")
}

model SanegoriaOffense {
  id          Int     @id @default(autoincrement())
  caseId      String  @map("case_id")
  offenseCode String? @map("offense_code")
  offenseName String? @map("offense_name")

  @@index([caseId])
  @@index([caseId, offenseCode])
  @@map("sanegoria_offenses")
}

// ─── Guideline Semantic Embeddings ───
//
// One row per Smart-DMS guideline document. The `embedding` column stores the
// OpenAI text-embedding-3-small vector (1536 floats) as a JSON array. We hash
// the text used for the embedding so the daily rebuild job can skip docs
// whose text hasn't changed.

// Tracks which Smart-DMS guideline docs have been chunked + embedded, so the
// daily rebuild can skip docs whose source text hasn't changed.
model GuidelineEmbedding {
  id          Int      @id // matches Smart-DMS doc id
  contentHash String   @map("content_hash")
  model       String
  textChars   Int      @map("text_chars")
  chunkCount  Int      @default(0) @map("chunk_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("guideline_embeddings")
}

// One row per chunk of a guideline document. We embed paragraph-sized
// windows so semantic search can match a specific section instead of an
// averaged-out vector for the whole 20K-char document.
model GuidelineChunk {
  id        Int    @id @default(autoincrement())
  docId     Int    @map("doc_id")
  chunkIdx  Int    @map("chunk_idx")
  text      String
  embedding Json
  model     String

  @@unique([docId, chunkIdx])
  @@index([docId])
  @@map("guideline_chunks")
}

// ─── Pach HaMishpat ─── //
// Community-driven status reporting for נט המשפט (Israel's court e-system).
// Ported from the standalone pah.org.il site into the main z-g.co.il app so
// it lives under /pach-hamishpat and shares the site's header/footer/admin.

model PachReport {
  id             Int       @id @default(autoincrement())
  status         String    @default("green") // "green" | "orange" | "red"
  description    String?
  reporterType   String    @default("user") @map("reporter_type") // "user" | "admin"
  createdDate    DateTime  @default(now()) @map("created_date")
  expiresAt      DateTime? @map("expires_at")
  isHidden       Boolean   @default(false) @map("is_hidden")
  isScheduled    Boolean   @default(false) @map("is_scheduled")
  scheduledFrom  DateTime? @map("scheduled_from")
  scheduledUntil DateTime? @map("scheduled_until")

  @@index([createdDate])
  @@index([isHidden, createdDate])
  @@map("pach_reports")
}

model PachComment {
  id          Int      @id @default(autoincrement())
  content     String
  authorName  String   @default("אנונימי") @map("author_name")
  isAdmin     Boolean  @default(false) @map("is_admin")
  isHidden    Boolean  @default(false) @map("is_hidden")
  createdDate DateTime @default(now()) @map("created_date")

  @@index([createdDate])
  @@map("pach_comments")
}

model PachSystemMessage {
  id          Int      @id @default(autoincrement())
  title       String?
  content     String?
  imageUrl    String?  @map("image_url")
  orderIndex  Int      @default(0) @map("order_index")
  isArchived  Boolean  @default(false) @map("is_archived")
  createdDate DateTime @default(now()) @map("created_date")

  @@index([isArchived, orderIndex])
  @@map("pach_system_messages")
}

// ─── WhatsApp Chat Workspaces ─── //
// Per-workspace SSO-gated chat archives. Each workspace can hold many chats
// (one per uploaded WhatsApp ZIP export). Access is controlled by the
// WhatsappWorkspaceAccess join table — only those emails (plus any ADMIN)
// can view the workspace. See src/lib/auth.ts + src/lib/whatsapp-auth.ts.

model WhatsappWorkspace {
  id          String                    @id @default(cuid())
  slug        String                    @unique // URL: /whatsapp/<slug>
  title       String // shown in admin list + as page title
  description String?
  chats       WhatsappChat[]
  access      WhatsappWorkspaceAccess[]
  // Workspace-scoped tag pool. Each tag can be attached to any number of
  // messages within the same workspace via WhatsappMessageTag. Tags do
  // not cross workspace boundaries.
  tags        WhatsappTag[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@map("whatsapp_workspaces")
}

model WhatsappWorkspaceAccess {
  id          String            @id @default(cuid())
  workspaceId String            @map("workspace_id")
  workspace   WhatsappWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Email is always stored lowercased. The signIn callback and per-route
  // gates both lowercase before comparing — never trust the raw value
  // from Google OAuth (Gmail addresses round-trip case-insensitive but
  // other Google Workspace domains may not).
  email       String
  createdAt   DateTime          @default(now())

  @@unique([workspaceId, email])
  @@index([email])
  @@map("whatsapp_workspace_access")
}

model WhatsappChat {
  id           String            @id @default(cuid())
  workspaceId  String            @map("workspace_id")
  workspace    WhatsappWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Derived from the ZIP filename ("WhatsApp Chat with X.zip" → "X"). The
  // chat .txt also embeds the contact name on every line but the filename
  // is the most reliable single source.
  contactName  String            @map("contact_name")
  // Raw sender string (as it appears in the .txt) that should be treated
  // as "me" → outgoing/green bubble. Null until the admin picks one in
  // the admin UI. Senders that don't match fall back to incoming/white.
  selfSender   String?           @map("self_sender")
  zipFilename  String            @map("zip_filename")
  messageCount Int               @default(0) @map("message_count")
  firstAt      DateTime?         @map("first_at")
  lastAt       DateTime?         @map("last_at")
  messages     WhatsappMessage[]
  media        WhatsappMedia[]
  uploadedAt   DateTime          @default(now()) @map("uploaded_at")

  @@index([workspaceId])
  @@index([workspaceId, lastAt])
  @@map("whatsapp_chats")
}

model WhatsappMessage {
  id        String               @id @default(cuid())
  chatId    String               @map("chat_id")
  chat      WhatsappChat         @relation(fields: [chatId], references: [id], onDelete: Cascade)
  timestamp DateTime
  // Raw sender string as exported. Empty for system messages (encryption
  // notice, joins, leaves). The UI compares it against WhatsappChat
  // .selfSender to decide outgoing (green) vs incoming (white).
  sender    String
  isSystem  Boolean              @default(false) @map("is_system")
  // Admin can hide individual messages. Hidden rows stay in the DB and
  // remain visible to ADMIN with a "hidden" badge, but are filtered out
  // of the GET response for allowlisted GUEST viewers.
  isHidden  Boolean              @default(false) @map("is_hidden")
  text      String? // null when message is media-only
  mediaId   String?              @map("media_id")
  media     WhatsappMedia?       @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  // 0-based position in the chat. Used as the sort key (timestamps are
  // not unique — multiple messages can land in the same minute) and as
  // a stable React key.
  order     Int
  // Many-to-many tag membership. The join row carries createdAt so we
  // can sort or show "tagged 2 days ago" later if needed.
  tags      WhatsappMessageTag[]

  @@index([chatId, order])
  @@map("whatsapp_messages")
}

model WhatsappMedia {
  id        String            @id @default(cuid())
  chatId    String            @map("chat_id")
  chat      WhatsappChat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  filename  String // original filename from the ZIP
  mimeType  String            @map("mime_type")
  size      Int // bytes
  // The actual file content. Postgres TOASTs values > 2KB so multi-MB
  // images / audio are stored out-of-line; we never SELECT this column
  // in listing queries — only the dedicated /api/whatsapp/media/[id]
  // streaming route reads it.
  data      Bytes
  messages  WhatsappMessage[]
  createdAt DateTime          @default(now()) @map("created_at")

  @@index([chatId])
  @@map("whatsapp_media")
}

// ─── Tag pools — per-feature, per-workspace/project ─── //
// WhatsappTag lives in a WhatsappWorkspace; TimelineTag lives in a
// TimelineProject. The pools are intentionally separate so unrelated
// matters never share a tag namespace. Both follow the same shape so
// the shared UI components can treat them interchangeably.

model WhatsappTag {
  id          String               @id @default(cuid())
  workspaceId String               @map("workspace_id")
  workspace   WhatsappWorkspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  // Hex colour like "#16a34a". Optional — UI auto-hashes a palette
  // colour from the name when null so the same tag looks consistent
  // across pages without an admin having to set a colour explicitly.
  color       String?
  createdAt   DateTime             @default(now()) @map("created_at")
  messages    WhatsappMessageTag[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("whatsapp_tags")
}

model WhatsappMessageTag {
  messageId String          @map("message_id")
  message   WhatsappMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  tagId     String          @map("tag_id")
  tag       WhatsappTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now()) @map("created_at")

  @@id([messageId, tagId])
  @@index([tagId])
  @@map("whatsapp_message_tags")
}

// ─── Timeline domain ─── //
// Mirrors WhatsappWorkspace / Chat / Message / Media but for
// hand-curated event timelines (action reports, searches, meetings,
// inter-party messages). Same access model + clean-view URL + admin
// UX. Events are entered manually or imported from CSV/JSON.

model TimelineProject {
  id          String                  @id @default(cuid())
  slug        String                  @unique // URL: /timeline/<slug>
  title       String
  description String?
  layers      TimelineLayer[]
  access      TimelineProjectAccess[]
  tags        TimelineTag[]
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  @@map("timeline_projects")
}

model TimelineProjectAccess {
  id        String          @id @default(cuid())
  projectId String          @map("project_id")
  project   TimelineProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Lowercased before storage; signIn + per-route checks compare
  // case-insensitively.
  email     String
  createdAt DateTime        @default(now()) @map("created_at")

  @@unique([projectId, email])
  @@index([email])
  @@map("timeline_project_access")
}

model TimelineLayer {
  id          String          @id @default(cuid())
  projectId   String          @map("project_id")
  project     TimelineProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Human title, shown in the sidebar. e.g. "פעולות חקירה",
  // "תכתובות צד א-ב". Long enough for context, kept under ~120 chars.
  title       String
  description String?
  // Mirrors WhatsappChat.selfSender: which actor in this layer should
  // render as "me" (green/outgoing). Null until the admin picks one;
  // everything reads as incoming when null.
  selfActor   String?         @map("self_actor")
  events      TimelineEvent[]
  media       TimelineMedia[]
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("timeline_layers")
}

model TimelineEvent {
  id        String             @id @default(cuid())
  layerId   String             @map("layer_id")
  layer     TimelineLayer      @relation(fields: [layerId], references: [id], onDelete: Cascade)
  timestamp DateTime
  // Free-form category string; UI knows about a fixed set
  // ("action" | "search" | "message" | "meeting" | "note") for accent
  // colour + icon. Unknown values fall back to "note".
  category  String             @default("note")
  // For messages/meetings: the speaker. For actions/searches: the
  // operator who performed the action. Empty allowed (system event).
  actor     String
  // Optional short headline rendered above the body in the bubble.
  title     String?
  body      String?
  isHidden  Boolean            @default(false) @map("is_hidden")
  mediaId   String?            @map("media_id")
  media     TimelineMedia?     @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  order     Int
  tags      TimelineEventTag[]

  @@index([layerId, order])
  @@index([layerId, timestamp])
  @@map("timeline_events")
}

model TimelineMedia {
  id        String          @id @default(cuid())
  layerId   String          @map("layer_id")
  layer     TimelineLayer   @relation(fields: [layerId], references: [id], onDelete: Cascade)
  filename  String
  mimeType  String          @map("mime_type")
  size      Int
  data      Bytes
  events    TimelineEvent[]
  createdAt DateTime        @default(now()) @map("created_at")

  @@index([layerId])
  @@map("timeline_media")
}

model TimelineTag {
  id        String             @id @default(cuid())
  projectId String             @map("project_id")
  project   TimelineProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  createdAt DateTime           @default(now()) @map("created_at")
  events    TimelineEventTag[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("timeline_tags")
}

model TimelineEventTag {
  eventId   String        @map("event_id")
  event     TimelineEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tagId     String        @map("tag_id")
  tag       TimelineTag   @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now()) @map("created_at")

  @@id([eventId, tagId])
  @@index([tagId])
  @@map("timeline_event_tags")
}

// ─── Conditional Arrangements DB Storage ───
//
// Replaces the in-memory cache + per-request CKAN fetch that caused
// repeated V8 heap OOM crashes on Render Starter (512 MB).
//
// Architecture:
//   CaSync   – singleton row that records which CKAN resource IDs are
//              currently stored and when the last version-check ran.
//              A background job checks odata.org.il weekly; only when
//              the resource UUID changes is a full re-fetch triggered.
//
//   CaRecord – one row per arrangement (≈32 k police + 1.7 k prosecutor).
//              Storing here means API requests do a fast DB query instead
//              of loading 33 k objects into the Node.js heap.
//              `searchText` is a pre-normalised (lowercase, NFKD, no
//              cantillation) blob used for ILIKE '%term%' AND search.

model CaSync {
  id                   String   @id @default("singleton")
  policeResourceId     String?  @map("police_resource_id")
  prosecutorResourceId String?  @map("prosecutor_resource_id")
  laborResourceId      String?  @map("labor_resource_id")
  syncedAt             DateTime @default(now()) @map("synced_at")

  @@map("ca_sync")
}

model CaRecord {
  id           String  @id         // "police:1234" or "prosecutor:456"
  source       String              // "police" | "prosecutor"
  date         String?             // "YYYY-MM-DD", null when absent/unparseable
  district     String?             // שלוחה (police) or יחידה (prosecutor)
  offense      String?             // extracted statute clause
  fine         Int?
  compensation Int?
  description  String?             // full arrangement text (served by detail API)
  caseNumber   String?  @map("case_number")
  // Pre-normalised search blob for ILIKE '%term%' AND queries.
  searchText   String?  @map("search_text")

  @@index([source])
  @@index([source, date])
  @@index([date])
  // Facet + filter indexes — make distinct and WHERE queries fast
  // (without these, every facet/filter query does a full sequential scan of 33k rows)
  @@index([district])
  @@index([offense])
  @@index([source, district])
  @@index([source, offense])
  @@map("ca_records")
}
