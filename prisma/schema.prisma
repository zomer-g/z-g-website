generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role      @default(ADMIN)
  accounts      Account[]
  sessions      Session[]
  posts         Post[]
  createdAt     DateTime  @default(now())
}

model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  content     Json
  excerpt     String?
  coverImage  String?
  status      PostStatus @default(DRAFT)
  author      User       @relation(fields: [authorId], references: [id])
  authorId    String
  category    String?
  tags        String[]   @default([])
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  seoTitle    String?
  seoDesc     String?
}

model Page {
  id           String     @id @default(cuid())
  slug         String     @unique
  title        String
  content      Json
  draftContent Json?
  status       PageStatus @default(DRAFT)
  updatedAt    DateTime   @updatedAt
  publishedAt  DateTime?
  seoTitle     String?
  seoDesc      String?
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

model Service {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  description String
  content     Json
  icon        String?
  order       Int     @default(0)
  isActive    Boolean @default(true)
  seoTitle    String?
  seoDesc     String?
}

model Media {
  id        String   @id @default(cuid())
  url       String
  filename  String
  mimeType  String
  size      Int
  alt       String?
  createdAt DateTime @default(now())
}

model Submission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MediaAppearance {
  id           String   @id @default(cuid())
  title        String
  description  String
  type         String // "video" | "article" | "podcast"
  source       String
  date         String
  url          String?
  thumbnailUrl String?
  order        Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model SiteSettings {
  id   String @id @default("main")
  data Json
}

enum Role {
  ADMIN
  // GUEST users can sign in via SSO but only see WhatsApp workspaces
  // they're on the allowlist for. They cannot reach /admin or any other
  // private dashboard. The role is assigned at signIn time based on
  // whether the email is in ADMIN_EMAILS env or only in
  // WhatsappWorkspaceAccess rows.
  GUEST
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─── Sanegoria Dashboard (Criminal Proceedings Analysis) ───

model SanegoriaCase {
  id             Int       @id @default(autoincrement())
  caseId         String    @unique @map("case_id")
  caseName       String?   @map("case_name")
  acceptanceDate DateTime? @map("acceptance_date")
  closedDate     DateTime? @map("closed_date")
  verdict        String?
  courtId        String?   @map("court_id")
  isPd           Boolean   @default(false) @map("is_pd")
  isSole         Boolean   @default(false) @map("is_sole")

  @@index([isPd])
  @@index([courtId])
  @@index([acceptanceDate])
  @@index([verdict])
  @@index([isPd, acceptanceDate])
  @@index([isPd, courtId])
  @@index([isPd, verdict])
  @@index([isPd, acceptanceDate, courtId])
  @@index([isPd, acceptanceDate, verdict])
  @@map("sanegoria_cases")
}

model SanegoriaHearing {
  id          Int       @id @default(autoincrement())
  caseId      String    @map("case_id")
  meetingDate DateTime? @map("meeting_date")
  status      String?
  type        String?
  isPd        Boolean   @default(false) @map("is_pd")

  @@index([caseId])
  @@index([isPd])
  @@index([caseId, isPd])
  @@index([isPd, meetingDate])
  @@map("sanegoria_hearings")
}

model SanegoriaOffense {
  id          Int     @id @default(autoincrement())
  caseId      String  @map("case_id")
  offenseCode String? @map("offense_code")
  offenseName String? @map("offense_name")

  @@index([caseId])
  @@index([caseId, offenseCode])
  @@map("sanegoria_offenses")
}

// ─── Guideline Semantic Embeddings ───
//
// One row per Smart-DMS guideline document. The `embedding` column stores the
// OpenAI text-embedding-3-small vector (1536 floats) as a JSON array. We hash
// the text used for the embedding so the daily rebuild job can skip docs
// whose text hasn't changed.

// Tracks which Smart-DMS guideline docs have been chunked + embedded, so the
// daily rebuild can skip docs whose source text hasn't changed.
model GuidelineEmbedding {
  id          Int      @id // matches Smart-DMS doc id
  contentHash String   @map("content_hash")
  model       String
  textChars   Int      @map("text_chars")
  chunkCount  Int      @default(0) @map("chunk_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("guideline_embeddings")
}

// One row per chunk of a guideline document. We embed paragraph-sized
// windows so semantic search can match a specific section instead of an
// averaged-out vector for the whole 20K-char document.
model GuidelineChunk {
  id        Int    @id @default(autoincrement())
  docId     Int    @map("doc_id")
  chunkIdx  Int    @map("chunk_idx")
  text      String
  embedding Json
  model     String

  @@unique([docId, chunkIdx])
  @@index([docId])
  @@map("guideline_chunks")
}

// ─── Pach HaMishpat ─── //
// Community-driven status reporting for נט המשפט (Israel's court e-system).
// Ported from the standalone pah.org.il site into the main z-g.co.il app so
// it lives under /pach-hamishpat and shares the site's header/footer/admin.

model PachReport {
  id             Int       @id @default(autoincrement())
  status         String    @default("green") // "green" | "orange" | "red"
  description    String?
  reporterType   String    @default("user") @map("reporter_type") // "user" | "admin"
  createdDate    DateTime  @default(now()) @map("created_date")
  expiresAt      DateTime? @map("expires_at")
  isHidden       Boolean   @default(false) @map("is_hidden")
  isScheduled    Boolean   @default(false) @map("is_scheduled")
  scheduledFrom  DateTime? @map("scheduled_from")
  scheduledUntil DateTime? @map("scheduled_until")

  @@index([createdDate])
  @@index([isHidden, createdDate])
  @@map("pach_reports")
}

model PachComment {
  id          Int      @id @default(autoincrement())
  content     String
  authorName  String   @default("אנונימי") @map("author_name")
  isAdmin     Boolean  @default(false) @map("is_admin")
  isHidden    Boolean  @default(false) @map("is_hidden")
  createdDate DateTime @default(now()) @map("created_date")

  @@index([createdDate])
  @@map("pach_comments")
}

model PachSystemMessage {
  id          Int      @id @default(autoincrement())
  title       String?
  content     String?
  imageUrl    String?  @map("image_url")
  orderIndex  Int      @default(0) @map("order_index")
  isArchived  Boolean  @default(false) @map("is_archived")
  createdDate DateTime @default(now()) @map("created_date")

  @@index([isArchived, orderIndex])
  @@map("pach_system_messages")
}

// ─── WhatsApp Chat Workspaces ─── //
// Per-workspace SSO-gated chat archives. Each workspace can hold many chats
// (one per uploaded WhatsApp ZIP export). Access is controlled by the
// WhatsappWorkspaceAccess join table — only those emails (plus any ADMIN)
// can view the workspace. See src/lib/auth.ts + src/lib/whatsapp-auth.ts.

model WhatsappWorkspace {
  id          String                    @id @default(cuid())
  slug        String                    @unique // URL: /whatsapp/<slug>
  title       String // shown in admin list + as page title
  description String?
  chats       WhatsappChat[]
  access      WhatsappWorkspaceAccess[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@map("whatsapp_workspaces")
}

model WhatsappWorkspaceAccess {
  id          String            @id @default(cuid())
  workspaceId String            @map("workspace_id")
  workspace   WhatsappWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Email is always stored lowercased. The signIn callback and per-route
  // gates both lowercase before comparing — never trust the raw value
  // from Google OAuth (Gmail addresses round-trip case-insensitive but
  // other Google Workspace domains may not).
  email       String
  createdAt   DateTime          @default(now())

  @@unique([workspaceId, email])
  @@index([email])
  @@map("whatsapp_workspace_access")
}

model WhatsappChat {
  id           String            @id @default(cuid())
  workspaceId  String            @map("workspace_id")
  workspace    WhatsappWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Derived from the ZIP filename ("WhatsApp Chat with X.zip" → "X"). The
  // chat .txt also embeds the contact name on every line but the filename
  // is the most reliable single source.
  contactName  String            @map("contact_name")
  zipFilename  String            @map("zip_filename")
  messageCount Int               @default(0) @map("message_count")
  firstAt      DateTime?         @map("first_at")
  lastAt       DateTime?         @map("last_at")
  messages     WhatsappMessage[]
  media        WhatsappMedia[]
  uploadedAt   DateTime          @default(now()) @map("uploaded_at")

  @@index([workspaceId])
  @@index([workspaceId, lastAt])
  @@map("whatsapp_chats")
}

model WhatsappMessage {
  id        String         @id @default(cuid())
  chatId    String         @map("chat_id")
  chat      WhatsappChat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  timestamp DateTime
  // Raw sender string as exported. Empty for system messages (encryption
  // notice, joins, leaves). The UI compares it against the contactName
  // to decide outgoing-vs-incoming.
  sender    String
  isSystem  Boolean        @default(false) @map("is_system")
  text      String? // null when message is media-only
  mediaId   String?        @map("media_id")
  media     WhatsappMedia? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  // 0-based position in the chat. Used as the sort key (timestamps are
  // not unique — multiple messages can land in the same minute) and as
  // a stable React key.
  order     Int

  @@index([chatId, order])
  @@map("whatsapp_messages")
}

model WhatsappMedia {
  id        String            @id @default(cuid())
  chatId    String            @map("chat_id")
  chat      WhatsappChat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  filename  String // original filename from the ZIP
  mimeType  String            @map("mime_type")
  size      Int // bytes
  // The actual file content. Postgres TOASTs values > 2KB so multi-MB
  // images / audio are stored out-of-line; we never SELECT this column
  // in listing queries — only the dedicated /api/whatsapp/media/[id]
  // streaming route reads it.
  data      Bytes
  messages  WhatsappMessage[]
  createdAt DateTime          @default(now()) @map("created_at")

  @@index([chatId])
  @@map("whatsapp_media")
}
