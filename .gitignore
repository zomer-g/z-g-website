# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.production
.env.development
.env.*
!.env.example

# Ad-hoc one-off scripts. These are run locally against prod and have
# historically been written with credentials pasted inline. Tracked
# scripts are .ts and load config via `dotenv/config`; keep it that way.
# To track a .js script here, scrub it first, then force-add it.
/scripts/*.js

# vercel
.vercel

# claude
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# local crawler smoke test artifacts
/.tmp/
