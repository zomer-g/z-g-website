DATABASE_URL="postgresql://user:password@localhost:5432/zg_website"
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# Admin OAuth client — has the webmasters.readonly scope for /admin/seo.
# Kept in Google Testing mode; only ADMIN_EMAILS can sign in through it.
GOOGLE_CLIENT_ID="your-admin-google-client-id"
GOOGLE_CLIENT_SECRET="your-admin-google-client-secret"

# Public OAuth client — basic scopes only (openid/email/profile). Safe to
# publish in Google Cloud as a Production app (no verification needed for
# non-sensitive scopes). Used for guest sign-ins (e.g. /whatsapp workspace
# members). Leave unset if public SSO isn't enabled.
GOOGLE_CLIENT_ID_PUBLIC=""
GOOGLE_CLIENT_SECRET_PUBLIC=""
ADMIN_EMAILS="admin@example.com"
SITE_URL="http://localhost:3000"
TAGIT_API_URL="https://tag-it.biz"
# API key for the rulings endpoint (FOI scope=6, defamation scope=4).
# Issued by TAG-IT. Same scheme as CLASS_ACTION_API_KEY — sent as X-API-Key header.
RULINGS_API_KEY="your-tagit-rulings-api-key"

# ── TAG-IT local mirror ──
# Scope ids the in-app scheduler mirrors into tagit_docs (comma-separated).
# Unset → the built-in default (4,6,1). The rulings route falls back to live
# TAG-IT for any scope that isn't mirrored.
# TAGIT_MIRROR_SCOPES="4,6,1"
# Optional shared secret for triggering POST /api/rulings/sync from an
# external cron (x-sync-secret header). Admin sessions work without it.
# MIRROR_SYNC_SECRET=""

# ── SEO / Search Console ──
# Used by /admin/seo. Primary auth is OAuth via the admin user's Google account
# (the admin must be a verified owner of the GSC property). When the admin signs
# in, NextAuth requests the webmasters.readonly scope and stores the refresh
# token — no extra setup required beyond setting GSC_SITE_URL.
#
# The verified property URL exactly as it appears in Search Console:
# URL-prefix property: "https://z-g.co.il/"  |  Domain property: "sc-domain:z-g.co.il"
GSC_SITE_URL="sc-domain:z-g.co.il"
# Optional fallback: service account JSON. Only useful for Google Workspace
# properties where adding a service account as a GSC user is allowed.
# GSC_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Gemini API key (used both by the proofread tool and the AI keyword brainstorm in /admin/seo)
GEMINI_API_KEY="your-gemini-api-key"

# ── Billing dashboard (/admin/billing) ──
# READ-ONLY cost tracking across the paid infra providers. Every fetcher in
# src/lib/billing/ issues GET requests only. Any provider whose key is unset
# renders as a "not-configured" card — the page still works with a subset.
#
# Cloudflare — API Token scoped to "Billing → Read" only (truly read-only).
CLOUDFLARE_BILLING_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""
# Neon — API key (Account settings → API keys). Neon keys are full-access (no
# read-only scope); the fetcher only GETs. NEON_ORG_ID scopes the project list.
NEON_API_KEY=""
NEON_ORG_ID=""
# Render — API key (Account Settings → API keys). No cost API exists, so the
# card shows a plan-tier ESTIMATE, not real spend. Full-access key; GET only.
RENDER_API_KEY=""
# OpenAI — must be an ADMIN key (Organization → Admin keys), NOT an sk-proj-…
# project key. The Costs API needs the api.usage.read scope only admin keys have.
OPENAI_ADMIN_KEY=""
# DeepSeek — API key. Only exposes current balance (no spend history).
DEEPSEEK_API_KEY=""
# Google / Gemini cost (phase 3) — requires enabling Billing export → BigQuery
# and installing @google-cloud/bigquery, then a read-only service account
# (roles/bigquery.dataViewer + jobUser).
GCP_BILLING_BQ_PROJECT=""
GCP_BILLING_BQ_DATASET=""
GCP_BILLING_BQ_TABLE=""
GCP_SA_KEY_JSON=""
