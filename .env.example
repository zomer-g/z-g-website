DATABASE_URL="postgresql://user:password@localhost:5432/zg_website"
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# Admin OAuth client — has the webmasters.readonly scope for /admin/seo.
# Kept in Google Testing mode; only ADMIN_EMAILS can sign in through it.
GOOGLE_CLIENT_ID="your-admin-google-client-id"
GOOGLE_CLIENT_SECRET="your-admin-google-client-secret"

# Public OAuth client — basic scopes only (openid/email/profile).
# Safe to publish in Google Cloud as a Production app (no verification needed
# for non-sensitive scopes). Used for public-facing SSO. Leave unset if
# public SSO isn't enabled.
GOOGLE_CLIENT_ID_PUBLIC=""
GOOGLE_CLIENT_SECRET_PUBLIC=""
ADMIN_EMAILS="admin@example.com"
SITE_URL="http://localhost:3000"
TAGIT_API_URL="https://tag-it.biz"
TAGIT_USERNAME="your-tagit-email"
TAGIT_PASSWORD="your-tagit-password"

# ── SEO / Search Console ──
# Used by /admin/seo. Primary auth is OAuth via the admin user's Google account
# (the admin must be a verified owner of the GSC property). When the admin signs
# in, NextAuth requests the webmasters.readonly scope and stores the refresh
# token — no extra setup required beyond setting GSC_SITE_URL.
#
# The verified property URL exactly as it appears in Search Console:
# URL-prefix property: "https://z-g.co.il/"  |  Domain property: "sc-domain:z-g.co.il"
GSC_SITE_URL="sc-domain:z-g.co.il"
# Optional fallback: service account JSON. Only useful for Google Workspace
# properties where adding a service account as a GSC user is allowed.
# GSC_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Gemini API key (used both by the proofread tool and the AI keyword brainstorm in /admin/seo)
GEMINI_API_KEY="your-gemini-api-key"
